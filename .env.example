# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_APPLICATION_ID=your_application_id

# MegaLLM API
MEGALLM_API_KEY=your_megallm_api_key
MEGALLM_BASE_URL=https://ai.megallm.io/v1

# Model Configuration
AVAILABLE_MODELS=gpt-4,gpt-3.5-turbo,claude-3-opus,claude-3-sonnet
DEFAULT_MODEL=gpt-4
MODEL_ALIASES=gpt4:gpt-4,claude:claude-3-opus

# Bot Configuration
OWNER_IDS=123456789,987654321
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_USER=10
RATE_LIMIT_GLOBAL=200
DAILY_TOKEN_LIMIT_USER=50000
DAILY_TOKEN_LIMIT_SERVER=500000

# File Uploads
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=.txt,.pdf,.docx,.md

# Web Search (uses DuckDuckGo — no API key needed!)
# These are optional tuning parameters with sensible defaults
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_CACHE_TTL=300

# Database (Supabase PostgreSQL)
# ╔══════════════════════════════════════════════════════════════════════╗
# ║  IMPORTANT — Use the Session Pooler connection string!              ║
# ║  The direct connection (db.xxx.supabase.co) requires IPv6 which     ║
# ║  does NOT work on Railway, Render, or most VPS providers.           ║
# ║                                                                     ║
# ║  Go to: Supabase Dashboard → Project Settings → Database            ║
# ║         → Connection string → "Session Pooler" tab                  ║
# ╚══════════════════════════════════════════════════════════════════════╝
# Session Pooler URL (recommended — works on IPv4 networks, FREE):
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# If you paste a direct URL (db.xxx.supabase.co) it will be auto-converted,
# but you must also set SUPABASE_REGION below so the bot knows your region.

# Supabase region (only needed if using a direct DB URL for auto-conversion)
# Common regions: us-east-1, us-west-1, eu-west-1, ap-southeast-1
# SUPABASE_REGION=us-east-1

# Dodo Todo System \u2014 configured per-guild via /dodo setchannel (stored in DB)

# Railway
PORT=8080

