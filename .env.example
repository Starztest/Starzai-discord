# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_APPLICATION_ID=your_application_id

# ╔══════════════════════════════════════════════════════════════════════╗
# ║            LLM PROVIDERS — Multi-Provider AI System                 ║
# ║                                                                     ║
# ║  At least ONE provider API key is required.                         ║
# ║  Set as many as you want — the bot will automatically fall back     ║
# ║  to the next provider if one fails (rate limit, downtime, etc).     ║
# ║  All providers use OpenAI-compatible chat completions protocol.     ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Requesty.ai — Unified LLM Gateway (400+ models) ──────────────────
# Sign up: https://app.requesty.ai  →  API Keys  →  Create New Key
# Supports: OpenAI, Anthropic, Google, DeepSeek, Meta, Mistral and more
# Docs: https://docs.requesty.ai/quickstart
REQUESTY_API_KEY=
# REQUESTY_BASE_URL=https://router.requesty.ai/v1  # default, override if needed

# ── Featherless AI — Open-Source Models ───────────────────────────────
# Sign up: https://featherless.ai  →  Account  →  API Keys
# Supports: Qwen, Llama, Mistral, and thousands of open-source models
# Docs: https://featherless.ai/docs/quickstart-guide
FEATHERLESS_API_KEY=
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1  # default

# ── ModelsLab — LLM + Image Generation ───────────────────────────────
# Sign up: https://modelslab.com  →  Dashboard  →  API Keys
# Supports: LLM chat, image generation (50,000+ models)
# Docs: https://docs.modelslab.com
MODELSLAB_API_KEY=
# MODELSLAB_BASE_URL=https://modelslab.com/api/uncensored-chat/v1  # default

# ── Chutes.ai — Decentralized Serverless AI ──────────────────────────
# Sign up: https://chutes.ai/app  →  API Keys  →  Create
# Keys are prefixed cpk_
# Supports: DeepSeek, Llama, Qwen, and many open-source models
# Docs: https://chutes.ai/docs
CHUTES_API_KEY=
# CHUTES_BASE_URL=https://llm.chutes.ai/v1  # default

# ── Puter — Free AI API (OpenAI-compatible) ──────────────────────────
# Sign up: https://puter.com  →  Dashboard  →  Copy Auth Token
# FREE (user-pays model) — supports GPT-4o, Claude, Gemini, 500+ models
# Docs: https://developer.puter.com/tutorials/use-openai-sdk-with-puter/
PUTER_AUTH_TOKEN=
# PUTER_BASE_URL=https://api.puter.com/puterai/openai/v1  # default

# ── MegaLLM (Legacy) ─────────────────────────────────────────────────
# Still supported but optional if you have other providers above
MEGALLM_API_KEY=
# MEGALLM_BASE_URL=https://ai.megallm.io/v1  # default

# ── Provider Priority ────────────────────────────────────────────────
# Comma-separated list of provider names in order of preference.
# The bot tries the first available provider and falls back to the next
# on failure.  Only providers with a valid API key above will be used.
# Available: requesty, chutes, featherless, modelslab, puter, megallm
LLM_PROVIDER_PRIORITY=requesty,chutes,featherless,modelslab,puter,megallm

# ── Model Configuration ──────────────────────────────────────────────
# Models are organized into three tiers: Free, Premium, Ultra.
# Users browse them via /models and search via autocomplete on /set-model.
#
# DEFAULT_MODEL is what users get when they haven't picked a model yet.
DEFAULT_MODEL=gpt-4
#
# ── Model Tiers (comma-separated) ───────────────────────────────────
# Add your models to each tier.  If a tier is not set, sensible defaults
# are used.  Only models listed here will appear in /models for users.
# Provider routing is handled automatically — no need to specify providers.
#
# 🆓 Free tier — no cost models
# FREE_MODELS=gpt-4o-mini,gpt-3.5-turbo,gemini-2.0-flash,llama-3.1-8b,deepseek-v3,mistral-nemo
#
# ⭐ Premium tier — high-quality models
# PREMIUM_MODELS=gpt-4,gpt-4o,claude-3-sonnet,gemini-2.5-flash,deepseek-r1,llama-3.3-70b,mistral-large
#
# 👑 Ultra tier — top-tier flagship models
# ULTRA_MODELS=gpt-4.1,o3,o3-mini,claude-3-opus,claude-sonnet-4,gemini-2.5-pro
#
# AVAILABLE_MODELS is optional (legacy).  If set, these are added as
# extra valid names for backward compatibility.
# AVAILABLE_MODELS=gpt-4,gpt-3.5-turbo,claude-3-opus,claude-3-sonnet
#
# MODEL_ALIASES lets you define custom shortcuts, e.g. "smart" → gpt-4o.
# The registry already includes aliases like gpt4, claude, deepseek, etc.
MODEL_ALIASES=gpt4:gpt-4,claude:claude-3-opus

# Bot Configuration
OWNER_IDS=123456789,987654321
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_USER=10
RATE_LIMIT_GLOBAL=200
DAILY_TOKEN_LIMIT_USER=50000
DAILY_TOKEN_LIMIT_SERVER=500000

# File Uploads
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=.txt,.pdf,.docx,.md

# Web Search (uses DuckDuckGo — no API key needed!)
# These are optional tuning parameters with sensible defaults
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_CACHE_TTL=300

# Database (Supabase PostgreSQL)
# ╔══════════════════════════════════════════════════════════════════════╗
# ║  IMPORTANT — Use the Session Pooler connection string!              ║
# ║  The direct connection (db.xxx.supabase.co) requires IPv6 which     ║
# ║  does NOT work on Railway, Render, or most VPS providers.           ║
# ║                                                                     ║
# ║  Go to: Supabase Dashboard → Project Settings → Database            ║
# ║         → Connection string → "Session Pooler" tab                  ║
# ╚══════════════════════════════════════════════════════════════════════╝
# Session Pooler URL (recommended — works on IPv4 networks, FREE):
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# If you paste a direct URL (db.xxx.supabase.co) it will be auto-converted,
# but you must also set SUPABASE_REGION below so the bot knows your region.

# Supabase region (only needed if using a direct DB URL for auto-conversion).
# Must be a valid AWS region.  The bot will try to auto-correct typos and
# probe DNS if the region is wrong, but setting it correctly avoids delays.
# Valid: us-east-1, us-east-2, us-west-1, ca-central-1,
#        eu-west-1, eu-west-2, eu-west-3, eu-central-1, eu-central-2, eu-north-1,
#        ap-south-1, ap-southeast-1, ap-southeast-2, ap-northeast-1, ap-northeast-2,
#        sa-east-1
# SUPABASE_REGION=us-east-1

# Dodo Todo System — configured per-guild via /dodo setchannel (stored in DB)

# Railway
PORT=8080
